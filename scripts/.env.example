# 1C OData connection for build_snapshot.py — copy to scripts/.env and fill the password.
# scripts/.env is gitignored; keep it chmod 600; rotate the password periodically.
ODATA_URL=http://YOUR_1C_HOST:PORT/YOUR_BASE/odata/standard.odata/
ODATA_USER=__1C_ODATA_READONLY_USER__
ODATA_PASS=__PUT_PASSWORD_HERE__

# Where to write real.json. Default = ../app/public/assets/data/real.json (dev).
# In production point it at the directory nginx serves, e.g.:
# SNAPSHOT_OUT=/opt/biz-game/app/dist/assets/data/real.json
